# ==============================================================================
# TEMPLATE: Staging Environment Configurations
# Copy this file to 'tests/.env.staging' and update with actual staging secrets.
# NEVER commit the active 'tests/.env.staging' or '.env.staging' files to Git!
# ==============================================================================

# PostgreSQL Database Configuration
SPRING_DATASOURCE_USERNAME=cloudshare_staging_user
SPRING_DATASOURCE_PASSWORD=your_staging_db_password_here

# JWT Security Configurations
# Secret must be at least 512 bits (64 characters) for HMAC-SHA512
JWT_SECRET=your_staging_jwt_secret_key_at_least_64_characters_here
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# MinIO/S3 Root User and Password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_staging_minio_password_here

# Cryptography (32-byte master KEK in hex)
CRYPTO_MASTER_KEK=your_staging_crypto_master_kek_32_bytes_here

# Rate Limiting Configurations (adjust for staging/load testing if needed)
RATE_LIMIT_AUTH=10
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_LINK=50
RATE_LIMIT_GENERAL=200
RATE_LIMIT_ENABLED=true
