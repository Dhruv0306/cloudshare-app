# PostgreSQL Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cloudshare
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# Cache-Aside Redis Configuration
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Security Redis Configuration
SECURITY_REDIS_HOST=localhost
SECURITY_REDIS_PORT=6380

# JWT Security Configurations
# Secret must be at least 512 bits (64 characters) for HMAC-SHA512
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_please_change_this_value_in_env_file
JWT_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# MinIO Object Storage Configuration
MINIO_ROOT_USER=cloudshare_minio_user
MINIO_ROOT_PASSWORD=cloudshare_minio_password

# Cryptography Configurations
CRYPTO_MASTER_KEK=your_crypto_master_kek_32_bytes_please_change

# Rate Limiting Configurations (defaults shown)
RATE_LIMIT_AUTH=5
RATE_LIMIT_MFA=5
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_LINK=30
RATE_LIMIT_GENERAL=100
